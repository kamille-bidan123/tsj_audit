# API 配置
base_url = "https://api.anthropic.com/v1"
api_key = "sk-xxx-your-api-key-here"
model_name = "claude-sonnet-4-6"

# 功能开关
enable_lsp = false          # 启用 LSP 语言服务器
disable_exploit = false     # 禁用 ExploitAgent（不生成 PoC）
debug = false               # 启用调试模式

# 断点续审
resume = false              # 从输出目录的中间信息恢复审计

# 项目配置
project_path = "."          # 待审计的项目路径
scan = ""                   # 起始扫描脚本路径（留空则自动扫描）
max_turns = 50              # 审计最大轮数
output_dir = "output"       # 审计报告输出目录

# Skills 配置
skills_path = "skills"      # Skills 目录路径