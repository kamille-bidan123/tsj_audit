# API 配置
base_url = "https://api.anthropic.com/v1"
api_key = "sk-xxx-your-api-key-here"
model_name = "claude-sonnet-4-6"
deepseek_thinking = "disabled"    # DeepSeek V4 agent/tool 调用建议关闭 thinking
deepseek_reasoning_effort = ""    # thinking=enabled 时可设 high 或 max

# 功能开关
enable_lsp = false          # 启用 LSP 语言服务器
disable_exploit = false     # 禁用 ExploitAgent（不生成 PoC）
debug = false               # 启用调试模式

# 断点续审
resume = false              # 从输出目录的中间信息恢复审计

# 项目配置
project_path = "."          # 待审计的项目路径
scan = ""                   # 起始扫描脚本路径（留空则自动扫描）
max_turns = 50              # 基础轮次预算；LangGraph step 上限会结合 max_tool_calls 自动换算
max_tool_calls = 120        # 单个 runner 最大工具调用次数
max_repeated_tool_calls = 2 # 同一个工具同一参数最大重复次数
output_dir = "output"       # 审计报告输出目录

# Exploit sandbox 配置
exploit_backend = "opensandbox"       # Exploit 执行后端：opensandbox 或 filesystem
target_base_url = "http://localhost:8081"  # 远程 URL PoC 目标；localhost 仅代表 sandbox 内服务
opensandbox_image = "gcc:latest"      # OpenSandbox 容器镜像
opensandbox_project_dir = "/workspace/project"  # sandbox 内项目目录
opensandbox_timeout_seconds = 600     # OpenSandbox 生命周期超时
opensandbox_ready_timeout_seconds = 120  # OpenSandbox 就绪超时
opensandbox_upload_max_file_mb = 5    # 单文件上传上限
opensandbox_upload_excludes = ".git,.venv,__pycache__,output,audit_output,test_export_dir,.env,.env.local,.env.glm,.env.iflow"

# Skills 配置
skills_path = "skills"      # Skills 目录路径
