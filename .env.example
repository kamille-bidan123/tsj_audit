# Runtime 配置
agent_runtime = "codex"           # opencode / codex / claudecode
opencode_base_url = "http://127.0.0.1:4096"
opencode_provider_id = ""         # 例如 anthropic/openai；留空走 opencode 默认配置
opencode_model_id = ""            # 需与 provider_id 同时配置；留空走 opencode 默认配置
opencode_enable_event_stream = false  # 默认关闭 /event，使用轮询获取 tool/permission 日志
external_runtime_timeout_seconds = 1800

# 功能开关
disable_exploit = false     # 禁用 ExploitAgent（不生成 PoC）
enable_fallback_audit = false  # 启用兜底审计：已注册漏洞类型完成后，再审计其它安全问题
audit_types = []            # 额外显式启用的审计类型；skill.required_audit_types 会始终启用
debug = false               # 启用调试模式

# 断点续审
resume = false              # 从输出目录的中间信息恢复审计

# 项目配置
project_path = "."          # 待审计的项目路径
scan = ""                   # 起始扫描脚本路径（留空则自动扫描）
attack_surface_skill = ""   # 攻击面 skill 名；设置后自动发现入口函数，例如 civetweb_audit
output_dir = "output"       # 审计报告输出目录

# Exploit 配置
target_base_url = "http://localhost:8081"  # 远程 URL PoC 目标；localhost 仅代表 sandbox 内服务
